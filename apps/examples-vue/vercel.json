{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@squircle-js/examples-vue",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet ./ ../../packages/vue ../../pnpm-lock.yaml"
}
